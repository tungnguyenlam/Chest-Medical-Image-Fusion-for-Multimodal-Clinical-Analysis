# Copy to .env and fill in. .env is gitignored.

# HuggingFace access token with write access to the private dataset repo.
# Create at https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxx

# HuggingFace username or org used for bare --hf-repo names like "tung-thesis".
HF_USERNAME=your-hf-username

# Password used for 7z AES-256 encryption of the dataset bundle.
# Anyone extracting the archive needs this.
DATA_PASSWORD=change-me
